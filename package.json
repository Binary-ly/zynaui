{
  "name": "zynaui",
  "version": "0.1.1-beta.1",
  "description": "Tailwind CSS component library + D3 chart Web Components by Binary Tech Ltd",
  "author": "Binary Tech Ltd <hello@binary.ly>",
  "license": "MIT",
  "homepage": "https://zyna.dev",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/binary-ly/zynaui.git"
  },
  "keywords": [
    "tailwind",
    "tailwindcss",
    "tailwind-plugin",
    "ui",
    "components",
    "design-system",
    "d3",
    "charts",
    "web-components",
    "custom-elements",
    "dark-mode",
    "css-variables"
  ],
  "type": "module",
  "engines": {
    "node": ">=18.0.0"
  },
  "main": "dist/zyna-plugin.cjs",
  "module": "dist/zyna-plugin.js",
  "types": "types/index.d.ts",
  "exports": {
    ".": {
      "types": "./types/index.d.ts",
      "import": "./dist/zyna-plugin.js",
      "require": "./dist/zyna-plugin.cjs"
    },
    "./charts": {
      "types": "./types/charts.d.ts",
      "browser": "./dist/zyna-charts.js",
      "node": "./dist/zyna-charts-stub.cjs",
      "import": "./dist/zyna-charts.js",
      "require": "./dist/zyna-charts-stub.cjs"
    },
    "./style.css": "./dist/zynaui.css",
    "./genres": {
      "types": "./types/genres.d.ts",
      "import": "./dist/genres.js",
      "require": "./dist/genres.cjs"
    },
    "./react": {
      "types": "./types/react.d.ts",
      "import": "./dist/react.js",
      "require": "./dist/react.cjs"
    },
    "./charts/waffle": "./dist/charts/waffle.js",
    "./charts/timeline": "./dist/charts/timeline.js",
    "./charts/nightingale": "./dist/charts/nightingale.js",
    "./charts/lollipop": "./dist/charts/lollipop.js",
    "./charts/orbital": "./dist/charts/orbital.js"
  },
  "files": [
    "dist",
    "src",
    "types"
  ],
  "sideEffects": [
    "./dist/zyna-charts.js",
    "./dist/zyna-charts.cjs",
    "./dist/zyna-charts-stub.cjs",
    "./dist/zyna-charts.iife.js",
    "./dist/charts/waffle.js",
    "./dist/charts/timeline.js",
    "./dist/charts/nightingale.js",
    "./dist/charts/lollipop.js",
    "./dist/charts/orbital.js"
  ],
  "scripts": {
    "build": "vite build && vite build --config vite.iife.config.js && vite build --config vite.react.config.js && vite build --config vite.genres-docs.config.js && npm run build:css",
    "build:lib": "vite build",
    "build:iife": "vite build --config vite.iife.config.js",
    "build:css": "tailwindcss -i ./docs/input.css -o ./docs/zynaui.css && tailwindcss -i ./docs/input.css -o ./dist/zynaui.css && cp dist/zyna-charts.iife.js docs/dist/zyna-charts.iife.js",
    "dev": "vite build --watch",
    "preview": "vite preview --open docs/index.html",
    "dev:docs": "vite --config vite.docs.config.js",
    "preview:docs": "vite preview --config vite.docs.config.js",
    "test": "npm run test:plugin && npm run test:charts",
    "test:plugin": "vitest run",
    "test:charts": "web-test-runner"
  },
  "peerDependencies": {
    "d3-array": "^3.0.0",
    "d3-scale": "^4.0.0",
    "d3-selection": "^3.0.0",
    "d3-shape": "^3.0.0",
    "tailwindcss": ">=3.0.0",
    "react": ">=18.0.0"
  },
  "peerDependenciesMeta": {
    "tailwindcss": {
      "optional": true
    },
    "d3-selection": {
      "optional": true
    },
    "d3-array": {
      "optional": true
    },
    "d3-shape": {
      "optional": true
    },
    "d3-scale": {
      "optional": true
    },
    "react": {
      "optional": true
    }
  },
  "devDependencies": {
    "react": "^19.0.0",
    "@open-wc/testing": "^4.0.0",
    "@remcovaes/web-test-runner-vite-plugin": "^1.2.0",
    "@tailwindcss/cli": "^4.2.1",
    "@tailwindcss/postcss": "^4.2.1",
    "@tailwindcss/vite": "^4.2.1",
    "@web/test-runner": "^0.19.0",
    "d3-array": "^3.2.4",
    "d3-scale": "^4.0.2",
    "d3-selection": "^3.0.0",
    "d3-shape": "^3.2.0",
    "postcss": "^8.4.0",
    "tailwindcss": "^4.2.1",
    "vite": "^6.0.0",
    "vitest": "^3.0.0"
  }
}
